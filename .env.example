VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only values for WeChat/ClawBot integration.
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser code.
SUPABASE_SERVICE_ROLE_KEY=
BOT_WEBHOOK_SECRET=

# Optional: only needed if a public ClawBot-compatible send-message API calls
# reminders from Vercel. The OpenClaw server deployment uses
# server/openclaw/reminder-worker.mjs instead, so these can stay blank.
CLAWBOT_SEND_MESSAGE_URL=
CLAWBOT_SEND_MESSAGE_TOKEN=
BOT_TIME_ZONE=Asia/Shanghai

# LLM Configuration for advanced NLP parsing
# If empty, the bot will fall back to using hardcoded regular expressions.
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.deepseek.com/v1
VITE_OPENAI_MODEL=deepseek-chat
