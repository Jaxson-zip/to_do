{
  "name": "todo-memo-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && tsc -p tsconfig.api.json && vite build",
    "bot:build-api-runtime": "tsc -p tsconfig.api.runtime.json",
    "bot:openclaw:api": "node server/openclaw/bot-api-server.mjs",
    "bot:ilink:poll": "node server/openclaw/ilink-worker.mjs",
    "bot:openclaw:reminders": "node server/openclaw/reminder-worker.mjs",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "chrono-node": "^2.9.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vercel/node": "^5.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.5"
  }
}
